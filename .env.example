# Frontend - apenas variáveis VITE_* 
# Nunca coloque segredos aqui — o .env é exposto no bundle do cliente.

# ─── GCP / Firebase Auth ────────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=

# ─── API Base URL (Cloud Run) ───────────────────────────────────────
VITE_API_BASE_URL=https://clinicnest-api-XXXXXXX.southamerica-east1.run.app

# ─── Sentry (Frontend Error Tracking) ───────────────────────────────
# VITE_SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/xxx

# Opcionais
# VITE_GA_MEASUREMENT_ID=
# VITE_LOG_LEVEL=error
# VITE_STRIPE_LINK_MONTHLY=
# VITE_STRIPE_LINK_QUARTERLY=
# VITE_STRIPE_LINK_ANNUAL=

# TSA Serpro (Carimbo de Tempo)
VITE_SERPRO_CONSUMER_KEY=
VITE_SERPRO_CONSUMER_SECRET=

# BirdID - Certificado Digital em Nuvem (Soluti)
# Obtenha em: https://developers.birdid.com.br/
VITE_BIRDID_CLIENT_ID=
VITE_BIRDID_CLIENT_SECRET=
VITE_BIRDID_ENVIRONMENT=sandbox
# VITE_BIRDID_REDIRECT_URI= (padrão: {origin}/auth/birdid/callback)

# Firebase (Push Notifications)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=

# Cloudflare Turnstile (CAPTCHA)
# Obtenha em: https://dash.cloudflare.com/?to=/:account/turnstile
VITE_TURNSTILE_SITE_KEY=

# Banuba Face AR SDK (Detecção facial para consentimento)
# Obtenha em: https://www.banuba.com/face-ar-sdk
VITE_BANUBA_CLIENT_TOKEN=
