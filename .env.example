# Frontend - apenas variáveis VITE_* (Seção 4.10)
# Nunca coloque SUPABASE_SERVICE_ROLE_KEY, STRIPE_SECRET_KEY ou outros segredos aqui.
# O .env é usado apenas pelo Vite e expõe variáveis no bundle do cliente.

VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Opcionais
# VITE_GA_MEASUREMENT_ID=
# VITE_LOG_LEVEL=error
# VITE_STRIPE_LINK_MONTHLY=
# VITE_STRIPE_LINK_QUARTERLY=
# VITE_STRIPE_LINK_ANNUAL=

# TSA Serpro (Carimbo de Tempo)
VITE_SERPRO_CONSUMER_KEY=
VITE_SERPRO_CONSUMER_SECRET=

# BirdID - Certificado Digital em Nuvem (Soluti)
# Obtenha em: https://developers.birdid.com.br/
VITE_BIRDID_CLIENT_ID=
VITE_BIRDID_CLIENT_SECRET=
VITE_BIRDID_ENVIRONMENT=sandbox
# VITE_BIRDID_REDIRECT_URI= (padrão: {origin}/auth/birdid/callback)

# Firebase (Push Notifications)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=
