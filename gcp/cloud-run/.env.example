# Backend — Cloud Run environment variables
# Set in Secret Manager or Cloud Run env vars. Never commit real values.

# ─── Core ────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=8080

# ─── Database (Cloud SQL) ───────────────────────────────────────────
CLOUDSQL_CONNECTION_STRING=postgresql://user:pass@/clinicnest?host=/cloudsql/project:region:instance

# ─── Firebase Admin ─────────────────────────────────────────────────
# Option A: JSON key in env var (for local dev)
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}
# Option B: Default SA on Cloud Run (no config needed)

# ─── Frontend URL (for CORS) ────────────────────────────────────────
FRONTEND_URL=https://clinicnest.metaclass.com.br

# ─── Sentry (Backend Error Tracking) ────────────────────────────────
SENTRY_DSN=

# ─── Redis (Rate Limiting) ──────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Email (Resend) ─────────────────────────────────────────────────
RESEND_API_KEY=

# ─── Twilio (SMS/Voice) ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_TOKEN_TTL_SECONDS=3600

# ─── Stripe/Asaas (Payments) ────────────────────────────────────────
STRIPE_SECRET_KEY=
ASAAS_API_KEY=
ASAAS_API_BASE_URL=https://api.asaas.com

# ─── AI Services ────────────────────────────────────────────────────
OPENAI_API_KEY=
GCP_SERVICE_ACCOUNT_KEY=
GCP_REGION=southamerica-east1
GEMINI_MODEL=gemini-1.5-flash
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=

# ─── Internal Auth (Cron/Webhooks) ──────────────────────────────────
CRON_SECRET=
AUTOMATION_WORKER_KEY=
WEBHOOK_SECRET=
SUPERADMIN_USER_IDS=

# ─── Email ──────────────────────────────────────────────────────────
EMAIL_FROM=noreply@metaclass.com.br

# ─── Firebase Cloud Messaging ───────────────────────────────────────
FCM_SERVER_KEY=

# ─── URLs ────────────────────────────────────────────────────────────
SITE_URL=https://clinicnest.metaclass.com.br
PUBLIC_SITE_URL=https://clinicnest.metaclass.com.br
APP_URL=https://clinicnest.metaclass.com.br

# ─── WhatsApp (Evolution API) ───────────────────────────────────────
EVOLUTION_API_URL=
EVOLUTION_API_KEY=

# ─── GCP Storage ────────────────────────────────────────────────────
GCP_PROJECT_ID=

# ─── Logging ────────────────────────────────────────────────────────
# LOG_SENSITIVE=false
